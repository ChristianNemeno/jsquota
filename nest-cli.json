{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/rest",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "projects": {
    "rest": {
      "type": "application",
      "root": "apps/rest",
      "entryFile": "apps/rest/src/main",
      "sourceRoot": "apps/rest/src",
      "compilerOptions": {
        "tsConfigPath": "apps/rest/tsconfig.app.json"
      }
    },
    "graphql": {
      "type": "application",
      "root": "apps/graphql",
      "entryFile": "apps/graphql/src/main",
      "sourceRoot": "apps/graphql/src",
      "compilerOptions": {
        "tsConfigPath": "apps/graphql/tsconfig.app.json"
      }
    }
  }
}